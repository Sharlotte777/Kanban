<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.ratedwork">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:extractNativeLibs="true"
        android:name="androidx.multidex.MultiDexApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RatedWork">
        <activity
            android:name="ui.main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name="ui.main.EditTicketActivity" />
        <activity android:name="ui.main.BoardsActivity" />
        <activity android:name="ui.main.UsersActivity" />
        <activity android:name="ui.main.BoardEditActivity" />
        <activity android:name="ui.main.UserEditActivity" />
        <activity android:name="ui.main.SearchActivity" />
        <activity android:name="ui.main.SettingsActivity" />
    </application>
</manifest>